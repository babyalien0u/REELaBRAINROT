local RS = game:GetService("ReplicatedStorage")
local remote = RS:WaitForChild("RemoteHandler"):WaitForChild("StPatricksMerchantBuy")

-- Merchant items (LeprechaunsRod first)
local items = {
    "LeprechaunsRod",
    "StPatricksLuckyBlock",
    "LuckyCharm",
    "HeavyBobber",
    "LightBobber",
    "LuckPotion3",
    "MoneyPotion3",
    "LuckPotion2",
    "MoneyPotion2",
    "LuckPotion1",
    "MoneyPotion1"
}

local AutoBuy = false

local Toggle = MainTab:CreateToggle({
   Name = "AutoBuyAllStock",
   CurrentValue = false,
   Flag = "Toggle1",
   Callback = function(Value)

        AutoBuy = Value

        if AutoBuy then
            task.spawn(function()

                local bought = {}

                while AutoBuy do
                    local boughtSomething = false

                    for _,item in ipairs(items) do
                        if not bought[item] then
                            local success = pcall(function()
                                remote:InvokeServer(item)
                            end)

                            if success then
                                boughtSomething = true
                                print("Bought:", item)
                                bought[item] = true
                            end
                        end
                    end

                    if not boughtSomething then
                        print("All stock bought. Waiting for restock...")
                        bought = {}
                        task.wait(5)
                    else
                        task.wait(0.1)
                    end
                end

            end)
        end

   end,
})
