local running = false
local MAX_BACKPACK = 100

local Toggle = MainTab:CreateToggle({
    Name = "AutoEquip&Sell",
    CurrentValue = false,
    Flag = "Toggle_AutoFishEquipSell",
    Callback = function(Value)
        running = Value

        if running then
            task.spawn(function()
                local player = game.Players.LocalPlayer
                local backpack = player:WaitForChild("Backpack")

                while running do
                    -- Count backpack + equipped tools
                    local character = player.Character or player.CharacterAdded:Wait()
                    local equipped = 0

                    for _,v in pairs(character:GetChildren()) do
                        if v:IsA("Tool") then
                            equipped += 1
                        end
                    end

                    local total = #backpack:GetChildren() + equipped

                    if total < MAX_BACKPACK then
                        -- Only fish if backpack is NOT full
                        local fishArgs = {
                            "Caught",
                            2
                        }

                        game:GetService("ReplicatedStorage")
                            :WaitForChild("RemoteHandler")
                            :WaitForChild("Fishing")
                            :FireServer(unpack(fishArgs))

                        task.wait(0.1)

                    else
                        -- Backpack FULL → EquipBest
                        local equipArgs = {
                            "EquipBest",
                            "String",
                            "String"
                        }

                        game:GetService("ReplicatedStorage")
                            :WaitForChild("RemoteHandler")
                            :WaitForChild("Plot")
                            :FireServer(unpack(equipArgs))

                        -- Then SellMultiple
                        local sellArgs = {
                            {
                                Rare = true,
                                Legendary = true,
                                Secret = true,
                                Godly = true,
                                Epic = true,
                                Mythic = true,
                                Uncommon = true,
                                Divine = true
                            }
                        }

                        game:GetService("ReplicatedStorage")
                            :WaitForChild("RemoteHandler")
                            :WaitForChild("SellMultiple")
                            :FireServer(unpack(sellArgs))

                        -- Wait before starting the process again
                        task.wait(35)
                    end
                end
            end)
        end
    end,
})

